# ===========================================
# Flood Response Coordinator — Environment
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.

# Groq API Key (for LLM Agents)
GROQ_API_KEY=your-groq-api-key-here

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your-twilio-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# Mapbox Token (for frontend map)
MAPBOX_TOKEN=your-mapbox-token-here

# Offline Mode — set to true if no internet at demo venue
# When true: reads mock_rainfall.json instead of Open-Meteo API,
#             prints SMS to console instead of sending via Twilio
OFFLINE_MODE=true
